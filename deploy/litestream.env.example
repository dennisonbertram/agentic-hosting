# Litestream S3 replication credentials
# Copy to /etc/default/litestream and fill in the blanks.
# See docs/ops/litestream-replication.md for setup instructions.

LITESTREAM_BUCKET=ah-backups
LITESTREAM_ENDPOINT=https://s3.us-east-1.amazonaws.com
LITESTREAM_REGION=us-east-1
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
